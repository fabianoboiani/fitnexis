generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PERSONAL
  STUDENT
}

enum StudentStatus {
  ACTIVE
  PAUSED
  DELINQUENT
  INACTIVE
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
  TRANSFER
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  MISSED
}

enum StudentAppointmentResponseStatus {
  PENDING
  CONFIRMED
  RESCHEDULE_REQUESTED
  CANCELED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum StudentNoticeKind {
  INFO
  SUCCESS
  WARNING
}

enum StudentNoticePriority {
  LOW
  MEDIUM
  HIGH
}

enum StudentNoticeCategory {
  SESSION_REMINDER
  SCHEDULE_CHANGE
  PENDING_REQUEST
  CONFIRMATION_REQUIRED
  PAYMENT_ALERT
  PROGRESS_UPDATE
  SYSTEM
}

enum StudentNoticeEntityType {
  APPOINTMENT
  PAYMENT
  PROGRESS_RECORD
  STUDENT
  SYSTEM
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ownedTenant    Tenant?
  studentProfile Student?
}

model Tenant {
  id               String            @id @default(cuid())
  ownerUserId      String            @unique
  businessName     String
  personalName     String
  phone            String?
  email            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  ownerUser        User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  students         Student[]
  studentNotices   StudentNotice[]
  payments         Payment[]
  appointments     Appointment[]
  progressRecords  ProgressRecord[]
  saasSubscription SaaSSubscription?

  @@index([businessName])
  @@index([isActive])
}

model Student {
  id                  String        @id @default(cuid())
  tenantId            String
  userId              String?       @unique
  portalAccessEnabled Boolean       @default(false)
  name                String
  email               String?
  phone               String?
  birthDate           DateTime?
  goal                String?
  notes               String?
  status              StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  notices         StudentNotice[]
  payments        Payment[]
  appointments    Appointment[]
  progressRecords ProgressRecord[]

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, status])
  @@index([tenantId, name])
}

model StudentNotice {
  id                String                  @id @default(cuid())
  externalKey       String                  @unique
  tenantId          String
  studentId         String
  kind              StudentNoticeKind
  category          StudentNoticeCategory
  title             String
  description       String
  details           String
  priority          StudentNoticePriority
  isRead            Boolean                 @default(false)
  readAt            DateTime?
  relatedEntityType StudentNoticeEntityType?
  relatedEntityId   String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student           Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, studentId])
  @@index([studentId, isRead])
  @@index([studentId, priority])
  @@index([studentId, createdAt])
}

model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  studentId     String
  amount        Decimal       @db.Decimal(10, 2)
  dueDate       DateTime
  paidAt        DateTime?
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model Appointment {
  id                    String                           @id @default(cuid())
  tenantId              String
  studentId             String
  title                 String
  startsAt              DateTime
  endsAt                DateTime
  status                AppointmentStatus                @default(SCHEDULED)
  studentResponseStatus StudentAppointmentResponseStatus @default(PENDING)
  studentRespondedAt    DateTime?
  studentResponseNote   String?
  notes                 String?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  tenant                Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student               Student                          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([tenantId, startsAt])
  @@index([tenantId, status])
  @@index([tenantId, studentResponseStatus])
}

model ProgressRecord {
  id         String   @id @default(cuid())
  tenantId   String
  studentId  String
  recordedAt DateTime
  weight     Decimal? @db.Decimal(5, 2)
  bodyFat    Decimal? @db.Decimal(5, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@index([tenantId, recordedAt])
}

model SaaSSubscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  planName             String
  status               SubscriptionStatus @default(TRIAL)
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
}
